# ============================================================================
# SUPABASE / DATABASE Configuration
# ============================================================================

# Your Supabase project URL
# Example: https://abc123def456.supabase.co
SUPABASE_URL=your_supabase_url_here

# Supabase Service Role Key (from Settings → API)
# ⚠️  NEVER commit this to git - use .env.local for development
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct PostgreSQL connection string (optional, for migrations)
# Provided by Supabase
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# ============================================================================
# SCRAPER Configuration
# ============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Run browser with UI (false = headless)
HEADLESS=true

# Playwright timeout in milliseconds
PLAYWRIGHT_TIMEOUT=45000

# Enable verbose output
VERBOSE=false

# ============================================================================
# ENVIRONMENT
# ============================================================================

# development or production
NODE_ENV=development

# ============================================================================
# OPTIONAL: Rate Limiting & Retries
# ============================================================================

# Max concurrent browser instances
MAX_CONCURRENT_INSTANCES=1

# Retry attempts for failed products
MAX_RETRIES=3

# Exponential backoff multiplier (ms)
RETRY_BACKOFF_MULTIPLIER=1000

# ============================================================================
# OPTIONAL: Target Site Configuration
# ============================================================================

# Base URL of target B2B portal
TARGET_PORTAL_URL=https://your-b2b-portal.com

# Username/Email for portal login (if required)
PORTAL_USERNAME=

# Password for portal login (if required)
PORTAL_PASSWORD=
